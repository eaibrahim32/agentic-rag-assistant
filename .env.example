# --- LLM provider ---------------------------------------------
# Leave OLLAMA_BASE_URL alone if running Ollama locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Fallback. Works with any OpenAI-compatible endpoint.
# Groq example: OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Force a provider (skips the Ollama health probe). Used in CI.
FORCE_PROVIDER=

# --- Web search fallback --------------------------------------
# When the local corpus can't answer, search the web instead of giving up.
# Free key (1000 searches/month, no card): https://tavily.com
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=
WEB_SEARCH_RESULTS=3

# --- Retrieval ------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=knowledge
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_K=4
MAX_TRANSFORM_ATTEMPTS=1
